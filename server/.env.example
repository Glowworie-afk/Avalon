# ===== 服务端环境变量示例 =====
# 复制本文件为 .env 后填入真实值： cp .env.example .env
# 注意：真实的 WX_SECRET / JWT_SECRET 只放在 .env（已被 .gitignore 忽略），
#       本示例文件会进 git，千万不要把真实密钥写在这里。

# 服务监听端口
PORT=3000

# 本地联调开关：true = 跳过微信，直接用 code 当伪 openid
# 真机 / 正式联调时改成 false，并填好下面的 WX_APPID / WX_SECRET
MOCK_LOGIN=true

# 微信小程序凭证（在微信公众平台 -> 开发管理 -> 开发设置 里获取）
WX_APPID=
WX_SECRET=

# 签发 JWT 用的密钥。生产环境务必换成一段长随机字符串，例如：
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-only-change-me

# token 有效期（秒），默认 7 天
TOKEN_TTL=604800
